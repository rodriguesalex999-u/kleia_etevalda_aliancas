# Meta (Facebook) Conversions API
# Configure estas variáveis de ambiente na Vercel (Settings > Environment Variables)
# ou localmente em um arquivo .env (não commitar o .env)

# Pixel ID do Facebook (não é sensível, pode ficar no código)
FB_PIXEL_ID=1002683195582228

# Access Token da Conversions API (SENSÍVEL - configure na Vercel)
FB_ACCESS_TOKEN=seu_token_aqui

# Código de Teste para validação no Gerenciador de Eventos
FB_TEST_EVENT_CODE=TEST93047

# Mercado Pago (se aplicável)
MP_ACCESS_TOKEN=seu_token_mercado_pago_aqui

# Melhor Envio (se aplicável)
MELHORENVIO_TOKEN=seu_token_melhor_envio_aqui

# Endereço da loja para envio (se aplicável)
STORE_ADDRESS=Av. Historiador Rubens de Mendonça
STORE_NUMBER=4293
STORE_DISTRICT=Centro Político Administrativo
STORE_CEP=78049000
